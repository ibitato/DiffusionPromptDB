# =====================================================
# ENVIRONMENT VARIABLES - EXAMPLE CONFIGURATION
# =====================================================
# Copy this file to .env and update with your values
# IMPORTANT: NEVER commit .env to version control

# API Configuration
APP_NAME="DiffusionPromptDB API"
APP_VERSION="1.0.0"
APP_DESCRIPTION="REST API for Stable Diffusion Prompt Database and Catalogation"

# Server Configuration
HOST="0.0.0.0"
PORT=8000
RELOAD=False

# Database Configuration
PROMPTS_DB_PATH="database/prompts_catalog.db"
CATALOG_DB_PATH="database/prompts_catalog.db"
# For PostgreSQL in production:
# DATABASE_URL="postgresql://username:password@localhost:5432/diffusionpromptdb"

# Security Configuration - CRITICAL: CHANGE THESE VALUES!
# Generate a secure key with: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY="CHANGE-THIS-TO-A-SECURE-RANDOM-STRING"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=43200  # 30 days in minutes

# API Keys for read-only access (optional)
API_KEYS='["your-api-key-here","another-api-key"]'

# CORS Configuration
# Production domain: www.diffusionprompt.net
CORS_ORIGINS='["http://localhost:3000","http://localhost:3001","http://localhost:5173","https://www.diffusionprompt.net","https://diffusionprompt.net"]'
CORS_ALLOW_CREDENTIALS=True
CORS_ALLOW_METHODS='["*"]'
CORS_ALLOW_HEADERS='["*"]'

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# Pagination
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# Logging
LOG_LEVEL="INFO"
LOG_FILE="api.log"

# Bcrypt Configuration
BCRYPT_ROUNDS=12

# Rate Limiting Configuration (per endpoint type)
RATE_LIMIT_AUTH_LOGIN="5/minute"        # Login attempts (prevent brute force)
RATE_LIMIT_AUTH_REGISTER="3/minute"     # Registration attempts
RATE_LIMIT_AUTH_RESET="3/hour"          # Password reset requests
RATE_LIMIT_SEARCH="30/minute"           # Search operations
RATE_LIMIT_PUBLIC_READ="100/minute"     # Public read access
RATE_LIMIT_CATALOG="60/minute"          # Catalog browsing
RATE_LIMIT_PROMPT_CREATE="10/minute"    # Creating prompts
RATE_LIMIT_PROMPT_UPDATE="20/minute"    # Updating prompts
RATE_LIMIT_PROMPT_DELETE="10/minute"    # Deleting prompts
RATE_LIMIT_ADMIN="100/minute"           # Admin operations
RATE_LIMIT_HEALTH="10/minute"           # Health checks
RATE_LIMIT_DEFAULT="60/minute"          # Default fallback

# Production Mode
ENVIRONMENT="development"  # Change to "production" when deploying

# =====================================================
# INSTRUCTIONS:
# 1. Copy this file: cp .env.example .env
# 2. Generate a secure JWT_SECRET_KEY:
#    python -c "import secrets; print(secrets.token_urlsafe(32))"
# 3. Update CORS_ORIGINS with your production domain
# 4. Update database configuration if using PostgreSQL
# 5. Set ENVIRONMENT="production" for production deployment
# =====================================================
