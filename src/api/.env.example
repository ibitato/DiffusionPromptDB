# API Configuration
# Copy this file to .env and configure

# Server
HOST=0.0.0.0
PORT=8000
RELOAD=false

# Databases
PROMPTS_DB_PATH=../data/prompts.db
CATALOG_DB_PATH=../batch_analyzer/prompts_catalog.db

# Security - CHANGE THESE IN PRODUCTION!
API_KEYS=["your-api-key-here","another-api-key"]
JWT_SECRET_KEY=change-this-to-a-secure-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# Rate Limiting
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080"]

# Logging
LOG_LEVEL=INFO
LOG_FILE=api.log
