# AWS Credentials Configuration
# Copy this file to .env and fill in your credentials
# Alternative to using AWS CLI profiles

# Method 1: Use AWS Profile (Recommended)
AWS_PROFILE=default

# Method 2: Direct credentials (Less secure, not recommended for production)
# AWS_ACCESS_KEY_ID=your_access_key_here
# AWS_SECRET_ACCESS_KEY=your_secret_key_here
# AWS_SESSION_TOKEN=your_session_token_here  # Only if using temporary credentials

# AWS Region
AWS_DEFAULT_REGION=us-east-1

# Optional: S3 bucket for batch processing
# AWS_S3_BATCH_BUCKET=your-bucket-name

# Optional: Enable debug mode
# DEBUG=false
