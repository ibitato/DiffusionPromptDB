#!/bin/bash
# 🚀 DiffusionPromptDB - Production Server Setup Script
# Configurar variables antes de ejecutar

set -e  # Exit on error

echo "================================================================================"
echo "🚀 DiffusionPromptDB - Production Server Setup"
echo "================================================================================"

# Colors
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# ⚠️ CONFIGURAR ESTAS VARIABLES
DOMAIN="www.yourdomain.com"
PROJECT_DIR="/var/www/yourproject"
REPO_URL="https://github.com/yourusername/yourrepo.git"

# Step 1: Update system
echo -e "\n${GREEN}[1/10] Actualizando sistema...${NC}"
apt update && apt upgrade -y

# Step 2: Install dependencies
echo -e "\n${GREEN}[2/10] Instalando dependencias...${NC}"
apt install -y python3 python3-pip python3-venv nginx git curl ufw certbot python3-certbot-nginx nodejs npm build-essential

# Step 3: Firewall
echo -e "\n${GREEN}[3/10] Configurando firewall...${NC}"
ufw allow 22/tcp && ufw allow 80/tcp && ufw allow 443/tcp
echo "y" | ufw enable

# Step 4: Clone repository
echo -e "\n${GREEN}[4/10] Clonando repositorio...${NC}"
mkdir -p /var/www && cd /var/www
[ -d "$PROJECT_DIR" ] && cd $PROJECT_DIR && git pull || git clone $REPO_URL $PROJECT_DIR && cd $PROJECT_DIR

# Step 5: Python setup
echo -e "\n${GREEN}[5/10] Configurando Python...${NC}"
python3 -m venv .venv
source .venv/bin/activate
pip install --upgrade pip
pip install -r requirements.txt
pip install -r src/batch_analyzer/requirements.txt

# Step 6: Generate secrets
echo -e "\n${GREEN}[6/10] Generando secrets...${NC}"
JWT_SECRET=$(python3 -c "import secrets; print(secrets.token_urlsafe(32))")
API_KEY=$(python3 -c "import secrets; print(secrets.token_urlsafe(32))")
echo -e "${YELLOW}⚠️ GUARDAR ESTOS SECRETS:${NC}"
echo "JWT_SECRET_KEY: $JWT_SECRET"
echo "API_KEY: $API_KEY"

# Step 7: Backend .env
echo -e "\n${GREEN}[7/10] Configurando backend...${NC}"
cd $PROJECT_DIR/src/api
cat > .env << EOF
JWT_SECRET_KEY="$JWT_SECRET"
JWT_ALGORITHM="HS256"
JWT_EXPIRE_MINUTES=60
API_KEYS='["$API_KEY"]'
CORS_ORIGINS='["https://$DOMAIN","https://${DOMAIN#www.}"]'
HOST="0.0.0.0"
PORT=8000
RELOAD=false
PROMPTS_DB_PATH="database/prompts_catalog.db"
CATALOG_DB_PATH="database/prompts_catalog.db"
RATE_LIMIT_PER_MINUTE=100
RATE_LIMIT_PER_HOUR=1000
LOG_LEVEL="WARNING"
LOG_FILE="api.log"
EOF

# Step 8: Frontend
echo -e "\n${GREEN}[8/10] Building frontend...${NC}"
cd $PROJECT_DIR/frontend
npm install
cat > .env << EOF
VITE_API_URL=https://$DOMAIN/api
VITE_APP_URL=https://$DOMAIN
EOF
npm run build

# Step 9: Nginx con HTTPS 443
echo -e "\n${GREEN}[9/10] Configurando Nginx...${NC}"
mkdir -p /etc/nginx/ssl
openssl req -x509 -nodes -days 365 -newkey rsa:2048 \
    -keyout /etc/nginx/ssl/temp.key \
    -out /etc/nginx/ssl/temp.crt \
    -subj "/C=ES/ST=Madrid/L=Madrid/O=YourOrg/CN=$DOMAIN"

cat > /etc/nginx/sites-available/yoursite << 'NGINXEOF'
server {
    listen 80;
    listen [::]:80;
    server_name DOMAIN_PLACEHOLDER _;
    location /.well-known/acme-challenge/ { root /var/www/html; }
    location / { return 301 https://$server_name$request_uri; }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name DOMAIN_PLACEHOLDER;
    ssl_certificate /etc/nginx/ssl/temp.crt;
    ssl_certificate_key /etc/nginx/ssl/temp.key;
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_ciphers HIGH:!aNULL:!MD5;
    ssl_prefer_server_ciphers on;
    location / {
        root PROJECT_DIR_PLACEHOLDER/frontend/dist;
        try_files $uri $uri/ /index.html;
    }
    location /api {
        proxy_pass http://localhost:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header Strict-Transport-Security "max-age=31536000" always;
    gzip on;
}
NGINXEOF

sed -i "s|DOMAIN_PLACEHOLDER|$DOMAIN|g" /etc/nginx/sites-available/yoursite
sed -i "s|PROJECT_DIR_PLACEHOLDER|$PROJECT_DIR|g" /etc/nginx/sites-available/yoursite
ln -sf /etc/nginx/sites-available/yoursite /etc/nginx/sites-enabled/
rm -f /etc/nginx/sites-enabled/default
nginx -t

# Step 10: Systemd service
echo -e "\n${GREEN}[10/10] Configurando systemd...${NC}"
cat > /etc/systemd/system/yourapp-api.service << EOF
[Unit]
Description=YourApp API
After=network.target
[Service]
Type=simple
User=www-data
WorkingDirectory=$PROJECT_DIR/src/api
Environment="PATH=$PROJECT_DIR/.venv/bin"
ExecStart=$PROJECT_DIR/.venv/bin/python start_server.py
Restart=on-failure
RestartSec=10
[Install]
WantedBy=multi-user.target
EOF

chown -R www-data:www-data $PROJECT_DIR
systemctl daemon-reload
systemctl enable yourapp-api
systemctl start yourapp-api
systemctl restart nginx

echo -e "\n${GREEN}✅ Setup completado!${NC}"
echo -e "\n${YELLOW}PRÓXIMOS PASOS:${NC}"
echo "1. Configurar DNS apuntando a este servidor"
echo "2. Ejecutar: sudo certbot --nginx -d $DOMAIN"
echo "3. Verificar: https://$DOMAIN"
